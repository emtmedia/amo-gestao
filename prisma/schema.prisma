  nomeContribuinte      String
  telefone              String
  telefoneFixo          String?
  email                 String?
  dataEntrada           DateTime
  contaBancariaId       String
  valorContribuicao     Float
  metodoTransferenciaId String
  projetoDirecionado    String?
  eventoDirecionado     String?
  observacoes           String?
  arquivosReferencia    String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

// ============================================
// 17. RECEITA PESSOA JURÍDICA
// ============================================
model ReceitaPessoaJuridica {
  id                    String   @id @default(cuid())
  nomeEmpresa           String
  telefoneContato       String
  telefoneFixo          String?
  emailContato          String?
  dataEntrada           DateTime
  contaBancariaId       String
  valorContribuicao     Float
  metodoTransferenciaId String
  projetoDirecionado    String?
  eventoDirecionado     String?
  observacoes           String?
  arquivosReferencia    String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
