generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================
// 1. DEPARTAMENTOS
// ============================================
model Departamento {
  id                   String   @id @default(cuid())
  nome                 String
  telefoneFixo         String
  responsavelPrincipal String
  telefoneCelular      String
  emailResponsavel     String?
  descricao            String
  linkDepartamento     String?
  orcamentoAnual       Float?
  observacoes          String?
  arquivosReferencia   String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  projetos             ProjetoFilantropia[]
}

// ============================================
// 2. VOLUNTÁRIOS AMO
// ============================================
model VoluntarioAMO {
  id                 String   @id @default(cuid())
  nome               String
  cpf                String   @unique
  dataNascimento     DateTime
  enderecoCompleto   String
  genero             String
  competencias       String
  membroIgrejaOmega  Boolean  @default(false)
  fotografia         String?
  arquivosReferencia String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  voluntariosProjeto VoluntarioProjeto[]
  voluntariosEvento  VoluntarioEvento[]
}

// ============================================
// 3. PROJETOS DE FILANTROPIA
// ============================================
model ProjetoFilantropia {
  id                      String   @id @default(cuid())
  nome                    String
  dataInicio              DateTime
  dataEncerramento        DateTime
  responsavel             String
  emailResponsavel        String?
  telefoneResponsavel     String
  orcamentoEstimado       Float
  contaBancariaVinculada1 String?
  contaBancariaVinculada2 String?
  paisRealizacao          String   @default("Brasil")
  ufId                    String?
  cidadeId                String?
  estadoRealizacao        String?
  cidadeRealizacao        String?
  numeroVoluntarios       Int?
  departamentoId          String?
  comentarios             String?
  arquivosReferencia      String?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  departamento            Departamento?       @relation(fields: [departamentoId], references: [id])
  voluntarios             VoluntarioProjeto[]
  eventos                 Evento[]
  consolidacao            ConsolidacaoProjeto?
}

// ============================================
// 4. VOLUNTÁRIOS DO PROJETO
// ============================================
model VoluntarioProjeto {
  id                 String   @id @default(cuid())
  voluntarioId       String
  projetoId          String
  funcaoCargo        String
  cpf                String
  dataNascimento     DateTime
  dataInicio         DateTime
  dataSaida          DateTime?
  igrejaOrigem       String
  fotografia         String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  voluntario         VoluntarioAMO      @relation(fields: [voluntarioId], references: [id])
  projeto            ProjetoFilantropia @relation(fields: [projetoId], references: [id])
}

// ============================================
// 5. EVENTOS AVULSOS OU DE PROJETOS
// ============================================
model Evento {
  id                      String   @id @default(cuid())
  projetoVinculadoId      String?
  nome                    String
  dataInicio              DateTime
  dataEncerramento        DateTime
  responsavel             String
  emailResponsavel        String?
  telefoneResponsavel     String
  orcamentoEstimado       Float
  contaBancariaVinculada1 String?
  contaBancariaVinculada2 String?
  paisRealizacao          String   @default("Brasil")
  estadoRealizacao        String?
  cidadeRealizacao        String?
  enderecoGoogleMaps      String?
  numeroVoluntarios       Int?
  comentarios             String?
  arquivosReferencia      String?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  projeto                 ProjetoFilantropia? @relation(fields: [projetoVinculadoId], references: [id])
  voluntarios             VoluntarioEvento[]
  consolidacao            ConsolidacaoEvento?
}

// ============================================
// 6. VOLUNTÁRIOS DO EVENTO
// ============================================
model VoluntarioEvento {
  id                 String    @id @default(cuid())
  voluntarioId       String
  eventoId           String
  funcaoCargo        String
  cpf                String
  dataNascimento     DateTime
  dataInicio         DateTime
  dataSaida          DateTime?
  igrejaOrigem       String?
  fotografia         String?
  arquivosReferencia String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  voluntario         VoluntarioAMO @relation(fields: [voluntarioId], references: [id])
  evento             Evento        @relation(fields: [eventoId], references: [id])
}

// ============================================
// 7. UF (Unidades da Federação)
// ============================================
model UF {
  id        String   @id @default(cuid())
  codigo    String   @unique
  nome      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cidades   Cidade[]
}

// ============================================
// 8. CIDADES
// ============================================
model Cidade {
  id        String   @id @default(cuid())
  nome      String
  ufId      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  uf        UF @relation(fields: [ufId], references: [id])
}

// ============================================
// 9. CONDIÇÕES DE RECEITA
// ============================================
model CondicaoReceita {
  id        String   @id @default(cuid())
  nome      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================
// 10. CONTAS BANCÁRIAS
// ============================================
model ContaBancaria {
  id         String   @id @default(cuid())
  tipo       String   // Corrente, Poupança, Investimento
  banco      String
  agencia    String
  numeroConta String
  descricao  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ============================================
// 11. MÉTODOS DE TRANSFERÊNCIA/PAGAMENTO
// ============================================
model MetodoTransferencia {
  id        String   @id @default(cuid())
  nome      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================
// 12. CURSOS E TREINAMENTOS
// ============================================
model CursoTreinamento {
  id        String   @id @default(cuid())
  nome      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================
// 13. PRODUTOS
// ============================================
model Produto {
  id        String   @id @default(cuid())
  nome      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================
// 14. SERVIÇOS
// ============================================
model Servico {
  id        String   @id @default(cuid())
  nome      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================
// 15. RECEITA PÚBLICA
// ============================================
model ReceitaPublica {
  id                    String   @id @default(cuid())
  tipoReceita           String   // Municipal, Estadual, Federal, Outros
  ufId                  String?
  cidadeId              String?
  nomeOrgao             String
  nomeSetor             String
  nomeContato           String?
  telefoneContato       String?
  telefoneFixo          String?
  emailContato          String?
  condicaoReceitaId     String
  valorRecurso          Float
  dataEntrada           DateTime
  contaBancariaId       String
  metodoTransferenciaId String
  projetoDirecionado    String?
  eventoDirecionado     String?
  observacoes           String?
  arquivosReferencia    String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

// ============================================
// 16. RECEITA PESSOA FÍSICA
// ============================================
model ReceitaPessoaFisica {
